NODE_COUNT=10
SIMULATION_TICK_MS=500
FAILURE_INJECTION_ENABLED=true

REDIS_URL=redis://redis:6379
POSTGRES_DSN=postgresql://orbital:orbital@timescaledb:5432/orbital

API_HOST=0.0.0.0
API_PORT=8000

QUIC_CERT_PATH=/app/certs/cert.pem
QUIC_KEY_PATH=/app/certs/key.pem

ANOMALY_THRESHOLD=0.7
PROTOCOL_SWITCH_INTERVAL_S=5
HEARTBEAT_INTERVAL_S=5
HEARTBEAT_TIMEOUT_S=3
NODE_OFFLINE_TIMEOUT_S=30

LOG_LEVEL=INFO
LOG_FORMAT=json
